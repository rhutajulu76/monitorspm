function renderRekapDiModalScan(data) {
  if (data.length === 0) {
    $('#tabel-rekap-scan-body').html('<tr><td colspan="4" class="text-center text-muted small py-3">Belum ada rincian rekap.<br>Silakan isi rekap melalui tombol "Cek Rekap" pada tabel utama terlebih dahulu.</td></tr>');
    return;
  }
  let html = "";
  data.forEach(item => {
    const hasScan = item.urlScan && item.urlScan.trim() !== "";
    
    // Logika mengambil nama PIC Scan terakhir dari riwayat
    let picScanTampil = "-";
    if (item.picScan && item.picScan !== "-") {
      let picArray = item.picScan.split(";");
      picScanTampil = picArray[picArray.length - 1].trim(); // Ambil nama terakhir saja
    }

    const btnUpload = hasScan ?
      `<button class="btn btn-sm btn-outline-secondary py-0 px-2 fw-bold btn-upload-cepat" onclick="bukaUploadCepat('${item.kategori}', ${item.rowIndex}, ${item.nilai}, '${item.urlScan}')" disabled title="Ganti Bukti Scan"><i class="bi bi-pencil-square"></i> Edit</button>
      <a href="${item.urlScan}" target="_blank" class="btn btn-sm btn-info py-0 px-2 text-white" title="Lihat Dokumen"><i class="bi bi-eye"></i></a>` :
      `<button class="btn btn-sm btn-primary py-0 px-2 fw-bold btn-upload-cepat" onclick="bukaUploadCepat('${item.kategori}', ${item.rowIndex}, ${item.nilai}, '')" disabled title="Upload Bukti Scan"><i class="bi bi-upload"></i> Upload</button>`;

    html += `<tr>
      <td class="small fw-bold text-secondary text-start">${item.kategori}</td>
      <td class="small text-end fw-bold">Rp ${Number(item.nilai).toLocaleString('id-ID')}</td>
      <td class="text-center fw-bold text-primary">${picScanTampil}</td>
      <td class="text-center">${btnUpload}</td>
