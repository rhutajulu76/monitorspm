// ==========================================
// FUNGSI UPLOAD ATAU COPY LINK KE GOOGLE DRIVE
// ==========================================
function getBase64(file) {
return new Promise((resolve, reject) => {
const reader = new FileReader();
reader.readAsDataURL(file);
reader.onload = () => resolve(reader.result);
reader.onerror = error => reject(error);
});
}

async function handleUploadAndSave(fileInputId, linkInputId, spm, unitKerja, saveCallback) {
let fileInput = document.getElementById(fileInputId);
let linkInput = document.getElementById(linkInputId);

let hasFile = (fileInput && fileInput.files.length > 0);
let driveLink = (linkInput && linkInput.value.trim() !== "") ? linkInput.value.trim() : "";

if (hasFile) {
let file = fileInput.files[0];
if (file.size > 30 * 1024 * 1024) {
alert("Ukuran file terlalu besar! Maksimal 30MB.");
return false;
}
let base64 = await getBase64(file);
return new Promise((resolve) => {
google.script.run.withSuccessHandler(res => {
if (res.success) {
saveCallback(res.url);
resolve(true);
} else {
alert("Gagal upload file: " + res.message);
resolve(false);
}
}).uploadFileToDrive(base64, file.name, file.type, spm, unitKerja);
});
}
else if (driveLink !== "") {
return new Promise((resolve) => {
google.script.run.withSuccessHandler(res => {
if (res.success) {
saveCallback(res.url);
resolve(true);
} else {
alert("Gagal menyalin link: " + res.message);
resolve(false);
}
}).copyFileFromDriveLink(driveLink, spm, unitKerja);
});
}
else {
saveCallback(modeEdit ? urlScanLamaEdit : "");
return true;
}
}

