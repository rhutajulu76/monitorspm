// Fungsi Generate Captcha 4 Angka dengan Gambar (Canvas)
function generateCaptcha() {
  currentCaptcha = Math.floor(1000 + Math.random() * 9999).toString();
  captchaTimestamp = new Date().getTime(); // Catat waktu saat captcha baru dibuat [cite: 346, 347]

  const canvas = document.getElementById('display-captcha');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const width = canvas.width;
  const height = canvas.height;

  // Bersihkan background
  ctx.clearRect(0, 0, width, height);
  ctx.fillStyle = '#f1f5f9';
  ctx.fillRect(0, 0, width, height);

  // Buat efek titik-titik (noise/gangguan)
  for (let i = 0; i < 150; i++) {
    ctx.fillStyle = `rgba(100, 116, 139, ${Math.random() * 0.2})`;
    ctx.fillRect(Math.random() * width, Math.random() * height, 2, 2);
  }

  // Tulis angka dengan posisi dan ukuran acak
  const colors = ['#0f172a', '#1e293b', '#334155'];
  for (let i = 0; i < currentCaptcha.length; i++) {
    const char = currentCaptcha[i];
    const fontSize = Math.floor(Math.random() * 10) + 32; 
    const angle = (Math.random() - 0.5) * 0.5; 

    ctx.font = `bold ${fontSize}px "Courier New", Courier, monospace`;
    ctx.fillStyle = colors[Math.floor(Math.random() * colors.length)];

    ctx.save();
    const x = 15 + (i * 25);
    const y = 35 + (Math.random() - 0.5) * 6; 

    ctx.translate(x, y);
    ctx.rotate(angle);
    ctx.fillText(char, 0, 0);
    ctx.restore();
  }

  // Tambahkan garis coretan pink acak
  for (let i = 0; i < 2; i++) {
    ctx.beginPath();
    ctx.moveTo(Math.random() * 20, Math.random() * height);
    ctx.lineTo(width - (Math.random() * 20), Math.random() * height);
    ctx.strokeStyle = '#d946ef'; // Warna coretan pink
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }

  $('#input-captcha').val(''); // Kosongkan kolom setiap ganti gambar
}

