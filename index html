      <div id="login-role-area" style="display:none; text-align: left;">
        <h6 class="fw-bold text-primary mb-3 text-center">Pilih Akses</h6>
        <div class="mb-3">
          <label class="form-label small text-muted fw-bold">Login sebagai:</label>
          <p id="lbl-multi-nama" class="fw-bold text-dark mb-2 border-bottom pb-2"></p>
          <select id="login-role-select" class="form-select form-select-sm"></select>
        </div>
        <button class="btn btn-success w-100 fw-bold py-2 mb-2" onclick="lanjutLoginMulti()">
          <i class="bi bi-check-circle me-1"></i> Lanjut Masuk
        </button>
        <button class="btn btn-outline-secondary w-100 py-1 btn-sm" onclick="batalMultiLogin()">Batal</button>
      </div>

      <div class="text-start mt-3 pt-3 border-top">
        <small class="text-muted fw-semibold" style="font-size: 11px;">© 2026 — Direktorat Jenderal PSDKP.</small>
      </div>

    </div>
  </div>
</div>

<div id="main-dashboard">

