function setupWizard(modalId, btnSimpanId) {
let modalEl = document.getElementById(modalId);
if(!modalEl) return;
let tabList = modalEl.querySelectorAll('.nav-tabs .nav-link');
let btnLanjut = modalEl.querySelector('.btn-lanjut-tab');
let btnKembali = modalEl.querySelector('.btn-kembali-tab');
let btnSimpan = document.getElementById(btnSimpanId);

modalEl.addEventListener('shown.bs.tab', function (e) {
let activeTab = e.target;
let activeIndex = Array.from(tabList).indexOf(activeTab);
if (activeIndex === 0) { if(btnKembali) btnKembali.classList.add('d-none'); }
else { if(btnKembali) btnKembali.classList.remove('d-none'); }

if (activeIndex === tabList.length - 1) {
if(btnLanjut) btnLanjut.classList.add('d-none');
if(btnSimpan) btnSimpan.classList.remove('d-none');
} else {
if(btnLanjut) btnLanjut.classList.remove('d-none');
if(btnSimpan) btnSimpan.classList.add('d-none');
}
});
}

function nextTab(modalId) {
let modalEl = document.getElementById(modalId);
let tabList = Array.from(modalEl.querySelectorAll('.nav-tabs .nav-link'));
let activeIndex = tabList.findIndex(tab => tab.classList.contains('active'));
if (activeIndex < tabList.length - 1) { let nextTab = new bootstrap.Tab(tabList[activeIndex + 1]); nextTab.show(); }
}

function prevTab(modalId) {
let modalEl = document.getElementById(modalId);
let tabList = Array.from(modalEl.querySelectorAll('.nav-tabs .nav-link'));
let activeIndex = tabList.findIndex(tab => tab.classList.contains('active'));
if (activeIndex > 0) { let prevTab = new bootstrap.Tab(tabList[activeIndex - 1]); prevTab.show(); }
}

