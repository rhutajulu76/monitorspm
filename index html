filtered.forEach(d => { let oj = d['Jenis SPP/SPM'] || 'N/A'; let dj = oj; if (GROUP_GAJI_ASN.includes(oj)) dj = "GAJI ASN"; else if (GROUP_PPNPN.includes(oj)) dj = "PENGHASILAN PPNPN"; if(!stats[dj]) stats[dj] = { t: 0, f: 0, r: 0, s: 0 }; stats[dj].t++; ut.t++; if(d['Fisik'] === true) { stats[dj].f++; ut.f++; } if(d['Rekap'] === true) { stats[dj].r++; ut.r++; } if(d['Scan'] === true) { stats[dj].s++; ut.s++; } });
let h = ''; Object.keys(stats).sort().forEach(j => { let s = stats[j]; h += `<tr><td class="ps-2 fw-bold">${j}</td><td class="text-center bg-light fw-bold">${s.t}</td><td class="text-center">${s.f}</td><td>${renderProgressBar((s.f/s.t*100).toFixed(1), 'fisik')}</td><td class="text-center">${s.r}</td><td>${renderProgressBar((s.r/s.t*100).toFixed(1), 'rekap')}</td><td class="text-center">${s.s}</td><td>${renderProgressBar((s.s/s.t*100).toFixed(1), 'scan')}</td></tr>`; });
$('#tbody-detail-jenis').html(h || '<tr><td colspan="8" class="text-center">Tidak ada data</td></tr>'); let footerLabel = selUnit ? `TOTAL ${selUnit}` : 'TOTAL SEMUA UNIT';
if(ut.t > 0) $('#tfoot-detail-jenis').html(`<td class="ps-2 fw-bold">${footerLabel}</td><td class="text-center fw-bold">${ut.t}</td><td class="text-center">${ut.f}</td><td>${renderProgressBar((ut.f/ut.t*100).toFixed(1), 'fisik')}</td><td class="text-center">${ut.r}</td><td>${renderProgressBar((ut.r/ut.t*100).toFixed(1), 'rekap')}</td><td class="text-center">${ut.s}</td><td>${renderProgressBar((ut.s/ut.t*100).toFixed(1), 'scan')}</td>`); else $('#tfoot-detail-jenis').empty(); }

function renderProgressBar(val, type) { let colorClass = (type === 'fisik') ? 'bg-bar-blue' : (type === 'rekap') ? 'bg-bar-orange' : 'bg-bar-green';
return `<div class="progress-container"><div class="progress-fill ${colorClass}" style="width: ${val}%"></div><div class="progress-text">${val}%</div></div>`; }

