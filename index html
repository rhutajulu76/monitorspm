// --- FITUR AUTO LOGOUT 1 JAM ---
let idleTimer;

function resetIdleTimer() {
  // Hapus timer yang sedang berjalan
  clearTimeout(idleTimer);
  
  // Hanya jalankan timer jika user sedang berada di dalam Dashboard (bukan halaman login)
  if ($('#main-dashboard').is(':visible')) {
    idleTimer = setTimeout(function() {
      // Tindakan saat waktu habis (1 jam = 3.600.000 ms)
      alert("Sesi Anda telah berakhir. Silakan login kembali.");
      
      // Proses logout tanpa konfirmasi
      localStorage.removeItem('userSession');
      localStorage.removeItem('allProfiles');
      $('#main-dashboard').hide();
      $('#login-page').css('display', 'flex');
      $('#tbodySpm').empty();
      generateCaptcha();
      
    }, 60 * 60 * 1000); 
  }
}

// Daftar aktivitas yang dianggap "sedang bekerja" (mouse gerak, klik, ngetik, scroll)
['mousedown', 'mousemove', 'keypress', 'scroll', 'touchstart'].forEach(function(namaEvent) {
  window.addEventListener(namaEvent, resetIdleTimer, false);
});

function sinkronisasiBarisLokal(noSpm, totalRekapBaru) {
  let safeId = noSpm.replace(/[^a-zA-Z0-9]/g, '_');
  
  // 1. Cari data di memori lokal
  let idx = rawData.findIndex(d => d['No. SPP/SPM'] === noSpm);
  if (idx === -1) return;
  
  let d = rawData[idx];
  let pagu = Number(d['Jumlah Pengeluaran'] || 0);
  
  // 2. Kalkulasi ulang status Rekap berdasarkan total baru
  let statRekap = false;
  if (pagu > 0) {
    if (totalRekapBaru > pagu + 1) { statRekap = "TIDAK SESUAI"; }
    else if (totalRekapBaru >= pagu - 1) { statRekap = true; }
  }
  
  // 3. Simpan perubahan ke memori lokal agar tidak hilang saat difilter
  d['Rekap'] = statRekap;
  
  // 4. Update Tampilan Tombol Rekap secara langsung di tabel
  let warnaBtnRekap = ''; 
  let textBtnRekap = '';
  
  if (statRekap === "TIDAK SESUAI") {
    warnaBtnRekap = 'bg-danger text-white border-danger';
    textBtnRekap = '<i class="bi bi-exclamation-triangle-fill me-1"></i> Tdk Sesuai';
  } else if (statRekap === true) {
    warnaBtnRekap = 'bg-success text-white border-success';
    textBtnRekap = '<i class="bi bi-check-all me-1"></i> Selesai';
  } else {
    warnaBtnRekap = 'btn-outline-primary bg-white text-primary';
    textBtnRekap = 'Cek Rekap';
  }
  
  $(`#td-rekap-${safeId}`).html(`<button class="btn-status-seragam ${warnaBtnRekap}" onclick="bukaModalRekap('${noSpm}', ${pagu})">${textBtnRekap}</button>`);
  
  // 5. Update grafik/tabel rekapitulasi secara otomatis (karena sangat ringan)
  if (menuAktif === 'unit') { updateRekapUnit(); updateDetailJenisUnit(); }
  if (menuAktif === 'bagian') { updateRekapBagian(); }
}

function sinkronisasiScanLokal(noSpm) {
  let safeId = noSpm.replace(/[^a-zA-Z0-9]/g, '_');
  
  // 1. Cari data di memori lokal agar tidak hilang saat filter
  let idx = rawData.findIndex(d => d['No. SPP/SPM'] === noSpm);
  if (idx !== -1) {
    // Asumsi: Jika ada 1 saja yang diupload, kita tandai status scannya ada
    rawData[idx]['Scan'] = true; 
  }

  // 2. Desain tombol baru untuk tampilan tabel utama (Dashboard)
  // Sesuaikan class dan icon dengan desain tombol "Sudah Upload" di sistem Anda
  let btnScanBaru = `<button class="btn-status-seragam bg-success text-white border-success" onclick="bukaModalFolder('${noSpm}')">
                        <i class="bi bi-folder-check me-1"></i> Selesai
                     </button>`;
  
  // 3. Suntikkan tombol baru ke tabel Dashboard di belakang layar
  $(`#td-scan-${safeId}`).html(btnScanBaru);
}
