async function prosesUploadTambahan() {
let fileInput = document.getElementById('inp-scan-tambahan');
let linkInput = document.getElementById('inp-link-tambahan');

let hasFile = (fileInput && fileInput.files.length > 0);
let driveLink = (linkInput && linkInput.value.trim() !== "") ? linkInput.value.trim() : "";

if (!hasFile && driveLink === "") {
alert("Pilih minimal 1 dokumen atau Paste Link Drive terlebih dahulu!");
return;
}

$('#btn-upload-tambahan').prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Memproses...');

if (hasFile) {
let files = fileInput.files;
let total = files.length;
$('#upload-progress-text').show().text(`Mengunggah 0 dari ${total} dokumen...`);

let successCount = 0;
for (let i = 0; i < total; i++) {
let file = files[i];
if (file.size > 30 * 1024 * 1024) {
alert(`File ${file.name} terlalu besar (>30MB)! Lewati file ini.`);
continue;
}

$('#upload-progress-text').text(`Mengunggah file ${i + 1} dari ${total} (${file.name})...`);

try {
let base64 = await getBase64(file);
await new Promise((resolve, reject) => {
google.script.run.withSuccessHandler(res => {
if(res.success) { successCount++; resolve(res); }
else { reject(res.message); }
}).uploadFileToDrive(base64, file.name, file.type, aktifSpmFolder, aktifUnitFolder);
});
} catch(e) {
console.error("Gagal upload " + file.name + ": " + e);
}
}
selesaiUploadTambahan(`Berhasil mengunggah ${successCount} dokumen fisik!`);
}
else if (driveLink !== "") {
$('#upload-progress-text').show().text(`Menyalin dokumen dari Link Drive...`);

google.script.run.withSuccessHandler(res => {
if (res.success) {
selesaiUploadTambahan("Berhasil menyalin dokumen dari Link Drive!");
} else {
alert("Gagal menyalin dokumen: " + res.message);
resetTombolUploadTambahan(); 
}
}).copyFileFromDriveLink(driveLink, aktifSpmFolder, aktifUnitFolder);
}
}

