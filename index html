function prosesLogin() {
  let username = $('#login-username').val().trim();
  let password = $('#login-password').val().trim();
  let userCaptcha = $('#input-captcha').val().trim();
  
  // LOGIKA BARU: Cek apakah captcha sudah lewat 3 menit (180.000 milidetik)
  let waktuSekarang = new Date().getTime();
  if (waktuSekarang - captchaTimestamp > 3 * 60 * 1000) {
    alert("Kode CAPTCHA tidak valid.");
    generateCaptcha(); // Refresh captcha otomatis
    return;
  }

  if(!username || !password) {
    alert("Mohon isi Username dan Password!");
    return;
  }

  // VALIDASI CAPTCHA
  if(userCaptcha !== currentCaptcha) {
    alert("Kode Captcha salah! Silakan coba lagi.");
    generateCaptcha(); // Refresh captcha jika salah
    return;
  }

  $('#btn-login').html('<span class="spinner-border spinner-border-sm me-2"></span> Memeriksa...').prop('disabled', true);
  
  google.script.run.withSuccessHandler(function(res) {
     if(res.success) {
         // JIKA LOGIN BERHASIL: Cek apakah user punya banyak role/unit
         if(res.profiles.length > 1) {
             localStorage.setItem('allProfiles', JSON.stringify(res.profiles));
             let opsiHtml = res.profiles.map((p, index) => `<option value="${index}">${p.role}</option>`).join('');
             $('#login-role-select').html(opsiHtml);
             $('#lbl-multi-nama').text(res.profiles[0].nama);
             $('#login-form-area').hide();
             $('#login-role-area').show();
         } else {
             // Jika hanya punya 1 role, langsung masuk
             localStorage.setItem('allProfiles', JSON.stringify(res.profiles));
             localStorage.setItem('userSession', JSON.stringify(res.profiles[0]));
             masukDashboard(res.profiles[0]);
         }
     } else {
         // JIKA GAGAL (Password salah)
         alert(res.message);
         $('#btn-login').html('<i class="bi bi-box-arrow-in-right me-1"></i> Masuk Dashboard').prop('disabled', false);
         generateCaptcha(); // Ganti captcha baru karena gagal
     }
  }).validasiLoginUser(username, password);
}

