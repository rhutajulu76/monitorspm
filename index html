function masukDashboard(userData) {
  $('#login-page').hide();
  $('#main-dashboard').css('display', 'flex');

  // Update Tampilan Profil Navbar
  $('#nav-user-name').text(userData.nama);
  $('#drop-nama').text(userData.nama);
  $('#drop-role').text(userData.role);
  $('#drop-unit').text(userData.unitKerja);

  // Setup Switcher Role di Profil (jika punya banyak profil)
  let allProfiles = JSON.parse(localStorage.getItem('allProfiles'));
  if (allProfiles && allProfiles.length > 1) {
    let opsiHtml = allProfiles.map((p, index) => {
      let isSelected = (p.unitKerja === userData.unitKerja && p.role === userData.role) ? 'selected' : '';
      // Di sini kita ubah {p.unitKerja} menjadi {p.role} agar memunculkan Admin/User
      return `<option value="${index}" ${isSelected}>${p.role}</option>`;
    }).join('');
    $('#switch-unit-select').html(opsiHtml);
    $('#container-switch-unit, #divider-switch-unit').show();
  } else {
    $('#container-switch-unit, #divider-switch-unit').hide();
  }

  // Reset form login awal
  $('#login-username').val('');
  $('#login-password').val('');
