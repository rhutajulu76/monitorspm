        </div>

        <div class="mb-3 text-start"> 
          <div class="d-flex align-items-center mb-2 gap-2 mt-3">
             <canvas id="display-captcha" width="130" height="45" class="rounded border shadow-sm" style="cursor: pointer; background: #f8fafc;" onclick="generateCaptcha()" title="Klik gambar untuk ganti Captcha"></canvas>
             
             <div class="form-floating flex-grow-1">
               <input type="text" class="form-control" id="input-captcha" name="captcha" placeholder="Captcha" maxlength="4" required>
               <label for="input-captcha">Captcha</label>
