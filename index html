function ambilDataServer() { 
  $('#loading-overlay').fadeIn();
  
  // 1. Mengambil informasi dari sesi pengguna yang sedang login
  let sesi = localStorage.getItem('userSession');
  let userUnitKerja = "ALL"; // Default: tampilkan semua
  
  if(sesi) {
    let userData = JSON.parse(sesi);
    
    // --- 🌟 LOGIKA BARU UNTUK ADMIN ---
    // Kita cek dulu apa role-nya.Pastikan semuanya huruf kecil agar mudah dicocokkan.
    let role = userData.role ? userData.role.toString().toLowerCase() : "";
    
    // Jika role mengandung kata "admin", kita paksa hak akses unit kerjanya menjadi "ALL"
    if (role.includes("admin")) {
      userUnitKerja = "ALL";
    } else {
      // Jika bukan admin (misal: user biasa), baru kita set sesuai unit kerjanya
      userUnitKerja = userData.unitKerja;
    }
  }

  // 2. Mengirimkan parameter Unit Kerja ke server (Google Apps Script)
  google.script.run.withSuccessHandler(data => { 
    rawData = data; 
    if (data.error) {
       alert("Terjadi kesalahan: " + data.error);
       $('#loading-overlay').fadeOut();
       return;
    }
    
    // 3. Memasukkan data ke dalam variabel penyimpan
    dataUtama = [...rawData]; 
    dataRekapUnit = [...rawData]; 
    dataRekapBagian = [...rawData]; 
    
    // 4. Memperbarui tampilan
    populateDropdowns(data); 
    terapkanFilter(); 
    $('#loading-overlay').fadeOut(); 
    
  }).getSpmData(userUnitKerja); // Memanggil fungsi di code.gs dengan parameter baru
}

function populateDropdowns(data) { const getUnique = (k) => [...new Set(data.map(d => d[k]))].filter(Boolean).sort(); let allUnits = getUnique('Unit Kerja');
let otherUnits = allUnits.filter(u => u !== "SETDITJEN"); dynamicUnits = allUnits.includes("SETDITJEN") ? ["SETDITJEN", ...otherUnits] : otherUnits; let valUnit = $('#filter-unit').val();
let valJenis = $('#filter-jenis').val(); $('#filter-unit').html('<option value="">Semua Unit</option>' + dynamicUnits.map(u => `<option value="${u}">${u}</option>`).join(''));
$('#filter-jenis').html('<option value="">Semua Jenis</option>' + getUnique('Jenis SPP/SPM').map(j => `<option value="${j}">${j}</option>`).join('')); $('#filter-unit').val(valUnit); $('#filter-jenis').val(valJenis); $('#f-unit-rekap, #f-unit-detail').empty(); $('#f-unit-detail').append('<option value="">-- Semua Unit --</option>');
dynamicUnits.forEach(v => { $('#f-unit-rekap').append(`<option value="${v}">${v}</option>`); $('#f-unit-detail').append(`<option value="${v}">${v}</option>`); }); }

function terapkanFilter() {
const f = { unit: $('#filter-unit').val(), jenis: $('#filter-jenis').val(), fisik: $('#filter-fisik').val(), rekap: $('#filter-rekap').val(), scan: $('#filter-scan').val(), jenisTanggal: $('#filter-tgl-jenis').val(), tglAwal: $('#filter-tgl-awal').val(), tglAkhir: $('#filter-tgl-akhir').val() };
const res = rawData.filter(d => {
let matchUnit = (!f.unit || d['Unit Kerja'] === f.unit); let matchJenis = (!f.jenis || d['Jenis SPP/SPM'] === f.jenis);
let matchFisik = (f.fisik === "" || String(d['Fisik']) === f.fisik); let matchRekap = (f.rekap === "" || String(d['Rekap']) === f.rekap);
let matchScan = (f.scan === "" || String(d['Scan']) === f.scan); let matchTanggal = true;
if (f.tglAwal || f.tglAkhir) {
let targetDate = d[f.jenisTanggal];
if (!targetDate) { matchTanggal = false; } else { if (f.tglAwal && targetDate < f.tglAwal) matchTanggal = false;
if (f.tglAkhir && targetDate > f.tglAkhir) matchTanggal = false; }
}
if (menuAktif === 'utama') { return matchUnit && matchJenis && matchFisik && matchRekap && matchScan && matchTanggal; }
else { return matchTanggal; }
});

if (menuAktif === 'utama') { dataUtama = res; renderMainTable(dataUtama); }
else if (menuAktif === 'unit') { dataRekapUnit = res; updateRekapUnit(); updateDetailJenisUnit(); }
else if (menuAktif === 'bagian') { dataRekapBagian = res; updateRekapBagian(); }
}

